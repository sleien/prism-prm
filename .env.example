# ── Prism — personal relationship manager ───────────────────────────────────
# Copy this file to .env and adjust the values, then `docker compose up -d`.
# Generate secrets with:  openssl rand -hex 32

# ── Identity / reverse proxy (Traefik + Authentik), same pattern as music-it ──
APP_NAME=prism
ROOT_PATH=home.schneider.today
FRIENDLY_NAME=Prism

# Public URL the app is reachable at. Used for OIDC redirects and the CalDAV
# links written into Nextcloud. Behind Traefik this is https://${APP_NAME}.${ROOT_PATH}.
PUBLIC_URL=https://prism.home.schneider.today

# ── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=                      # REQUIRED — openssl rand -hex 32
PORT=8000                        # host port for local/dev runs (ignored behind Traefik)
COOKIE_SECURE=true               # true when served over HTTPS
TZ=Europe/Zurich

# ── Database (used by both the db service and the app) ─────────────────────────
POSTGRES_USER=prism
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=prism

# ── Authentik / OpenID Connect (multi-user SSO) ────────────────────────────────
# Prism authenticates IN-APP via Authentik OIDC (not Traefik forward-auth), so it
# can read the `groups` claim to drive public/group/private visibility and issue
# its own API tokens for CalDAV/mobile clients.
OIDC_ENABLED=true
# Issuer URL or full .well-known URL, e.g.
#   https://authentik.example.com/application/o/prism/
# Add this redirect URI to the Authentik provider:
#   ${PUBLIC_URL}/api/auth/oidc/callback
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISPLAY_NAME=Authentik
OIDC_SCOPES=openid email profile
# Members of this Authentik group become Prism admins (optional).
OIDC_ADMIN_GROUP=prism-admins
# Allow local email/password registration in addition to SSO. Set false to
# require Authentik for all accounts.
ALLOW_REGISTRATION=false

# ── Nextcloud (contact source of truth + calendar target) ──────────────────────
# Base URL of your Nextcloud, NO trailing slash.
NEXTCLOUD_URL=https://cloud.example.com
# A Nextcloud user and an APP PASSWORD
# (Nextcloud → Settings → Security → "Devices & sessions" → Create new app password).
NEXTCLOUD_USERNAME=
NEXTCLOUD_APP_PASSWORD=
# Address book + calendar slugs as they appear in Nextcloud's DAV URLs.
NEXTCLOUD_ADDRESSBOOK=contacts
NEXTCLOUD_CALENDAR=personal
# How often (minutes) Prism pulls contacts down from Nextcloud.
SYNC_INTERVAL_MINUTES=15

# ── Weather enrichment (optional, Open-Meteo — no API key required) ────────────
WEATHER_ENABLED=true

# ── Image (when not building locally) ──────────────────────────────────────────
# IMAGE=ghcr.io/sleien/prism-prm:latest
